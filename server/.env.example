# Turneo Proxy Server — Environment Variables
# Copy this file to .env and fill in your values.

# Turneo API key (required for production)
TURNEO_API_KEY=mock

# Turneo Store ID — filters experiences to those curated by this hotel store.
# Leave empty to return all experiences (no store filter applied).
TURNEO_STORE_ID=

# Turneo API base URL
# Production: https://api.pro.turneo.co
# Mock:       https://stoplight.io/mocks/turneo/turneo-experiences-api/45542131
TURNEO_BASE_URL=https://stoplight.io/mocks/turneo/turneo-experiences-api/45542131

# Server port
PORT=3001

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:6006
