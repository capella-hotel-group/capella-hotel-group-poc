{
  "name": "capella-hotel-group-poc",
  "version": "1.0.0",
  "private": true,
  "description": "Capella Hotel Group PoC — Adobe Edge Delivery Services",
  "type": "module",
  "scripts": {
    "aem:up": "aem up",
    "build": "tsc && vite build -c vite.config.ts && vite build -c vite.config-editor.ts",
    "build:watch": "npm-run-all --parallel tsc:watch vite:watch vite:watch:editor",
    "tsc:watch": "tsc -w",
    "vite:watch": "vite build -w -c vite.config.ts",
    "vite:watch:editor": "vite build -w -c vite.config-editor.ts",
    "start": "npm-run-all --parallel tsc:watch vite:watch vite:watch:editor aem:up",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:json": "npm-run-all --parallel build:json:models build:json:definitions build:json:filters",
    "build:json:models": "merge-json-cli -i \"src/models/_component-models.json\" -o \"component-models.json\"",
    "build:json:definitions": "merge-json-cli -i \"src/models/_component-definition.json\" -o \"component-definition.json\"",
    "build:json:filters": "merge-json-cli -i \"src/models/_component-filters.json\" -o \"component-filters.json\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ],
    "*.{html,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/three": "^0.183.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-xwalk": "github:adobe-rnd/eslint-plugin-xwalk",
    "husky": "9.1.1",
    "jsonc-eslint-parser": "^3.1.0",
    "lint-staged": "^16.4.0",
    "merge-json-cli": "^1.0.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0"
  }
}
